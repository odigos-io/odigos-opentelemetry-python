ARG PYTHON_VERSION=3.11
FROM python:${PYTHON_VERSION}-slim

RUN pip install uv

WORKDIR /python-instrumentation
COPY dist/ /tmp/dist/
COPY tests/integration/configurator/ /tmp/configurator/

# Install all local wheels by path (forces uv to use them instead of PyPI),
# plus the local configurator. Remaining transitive deps come from PyPI.
# --find-links ensures custom instrumentation wheels in dist/ are also found.
RUN uv pip install --find-links=/tmp/dist/ --target workspace --system \
    /tmp/dist/*.whl \
    /tmp/configurator/ \
    && rm -rf /tmp/dist/ /tmp/configurator/
